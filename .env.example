APP_NAME=JuntaOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_FAKER_LOCALE=pt_PT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- PostgreSQL / Neon (produção) ---
DB_CONNECTION=pgsql
DB_HOST=ep-xxx.eu-central-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=juntaos
DB_USERNAME=juntaos_owner
DB_PASSWORD=
DB_SSLMODE=require

# --- SQLite (desenvolvimento local) ---
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@juntaos.pt"
MAIL_FROM_NAME="${APP_NAME}"

# --- JuntaOS Settings ---
JUNTAOS_UPLOAD_MAX_SIZE=10240
JUNTAOS_EXPORT_LIMIT=5000
JUNTAOS_DEFAULT_PAGINATION=15
JUNTAOS_DEMO_MODE=false
JUNTAOS_ORG_DEFAULT_CODE=DEMO

VITE_APP_NAME="${APP_NAME}"
